<style>
/* Center logo - opening (page refresh), nav button, footer gnav */
.opening {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
.opening .logo {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
.opening .logo img {
  display: block !important;
}
.gnav_wrapper .button a[href="/index.html"] {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  padding: 0 !important;
}
.gnav_wrapper .button .logo {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
.gnav__head .logo {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
.gnav__head .logo a {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}
/* PC端：避免换行后单字成行（orphan），参考 text-wrap: pretty 成熟方案 */
@media (min-width: 769px) {
  .think_list .description,
  .think_list p.description,
  section .description {
    text-wrap: pretty;
  }
  .think_list h3.heading,
  .think_list .heading {
    text-wrap: balance;
  }
}
/* 隐藏 VIEW ALL 按钮 */
.topics__head .button {
  display: none !important;
}
/* 隐藏首页 SERVICE 区块（完整版见 service/index.html） */
section.service#service {
  display: none !important;
}
/* FV ヒーローコピー：意図どおり3行のみ。各行は折り返さない（「力になる」を分割しない） */
.fv .copy__text {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
.fv .copy__text .fv-copy-line {
  display: block;
  white-space: nowrap;
}
/* WE WORK：移动端单图展示，不使用横向 Embla 循环 */
.think_list .photo .mb_only .think__photo_static {
  width: 100%;
  overflow: hidden;
}
.think_list .photo .mb_only .think__photo_static img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}
/* TOPICS 列表：移动端隐藏「コラム」；日期与标题纵向排列（解除主题的 grid + display:contents 重叠） */
@media (max-width: 768px) {
  section.topics .-topic_item .category {
    display: none !important;
  }
  .top_page .topics__main .-topic_list li a {
    display: flex !important;
    align-items: flex-start !important;
    gap: 12px;
    position: relative;
    padding-right: 40px;
  }
  .top_page .topics__main .-topic_list li .thumb {
    flex-shrink: 0;
    width: 88px;
    max-width: 30vw;
    aspect-ratio: 150 / 110;
    grid-row: auto !important;
    grid-column: auto !important;
  }
  .top_page .topics__main .-topic_list li .group {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0.35rem !important;
    flex: 1 1 auto !important;
    min-width: 0 !important;
  }
  .top_page .topics__main .-topic_list li .group .date {
    grid-column: unset !important;
    grid-row: unset !important;
  }
  .top_page .topics__main .-topic_list li .group .heading {
    grid-row: unset !important;
    grid-column: unset !important;
    margin-top: 0 !important;
    width: 100%;
    box-sizing: border-box;
  }
  .top_page .topics__main .-topic_list li .link {
    position: absolute !important;
    right: 0 !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    bottom: auto !important;
  }
}
</style>
